#!/bin/bash
# Ecclesiastic Wallpapers — set fine art as your wallpaper
# https://github.com/rogersebastiany/ecclesiastic-wallpapers

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/platform.sh"
source "${SCRIPT_DIR}/../ecclesiastic.conf"

mkdir -p "$POOL_DIR" "$META_DIR" "$COMPOSE_DIR" "$(dirname "$DB_PATH")"

sqlite3 "$DB_PATH" "CREATE TABLE IF NOT EXISTS paintings (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    met_id TEXT,
    title TEXT,
    artist TEXT,
    date TEXT,
    style TEXT,
    medium TEXT,
    dimensions TEXT,
    credit TEXT,
    url TEXT,
    rating INTEGER DEFAULT 0,
    shown_at TEXT DEFAULT (datetime('now','localtime')),
    rated_at TEXT
);" 2>/dev/null

pick_from_pool() {
    local style="$1"
    local exclude="$2"
    local candidates

    if [ -n "$style" ]; then
        candidates=$(grep -rl "^style=${style}$" "$META_DIR" 2>/dev/null | while read -r m; do
            local fname=$(basename "$m" .meta)
            [ -f "$POOL_DIR/$fname" ] && echo "$POOL_DIR/$fname"
        done)
    fi

    if [ -z "$candidates" ]; then
        candidates=$(find "$POOL_DIR" -maxdepth 1 -name '*.jpg' 2>/dev/null)
    fi

    [ -n "$exclude" ] && candidates=$(echo "$candidates" | grep -v "$exclude")

    echo "$candidates" | shuf -n1
}

fetch_live() {
    local style="$1"
    local encoded=$(echo "$style" | sed 's/ /+/g')

    local ids=$(curl -sL "https://collectionapi.metmuseum.org/public/collection/v1/search?hasImages=true&medium=Paintings&q=${encoded}" \
        | python3 -c "
import sys, json, random
d = json.load(sys.stdin)
ids = d.get('objectIDs', [])
if not ids: sys.exit(1)
sample = random.sample(ids, min(10, len(ids)))
print(' '.join(str(i) for i in sample))
" 2>/dev/null)

    [ -z "$ids" ] && return 1

    for oid in $ids; do
        local data=$(curl -sL "https://collectionapi.metmuseum.org/public/collection/v1/objects/${oid}")
        local img=$(echo "$data" | python3 -c "
import sys, json
d = json.load(sys.stdin)
img = d.get('primaryImage', '')
if img and d.get('isPublicDomain', False): print(img)
" 2>/dev/null)

        [ -z "$img" ] && continue

        local fname="met-${oid}.jpg"
        local dest="$POOL_DIR/$fname"

        [ -f "$dest" ] && continue

        curl -sL "$img" -o "$dest"
        [ -s "$dest" ] || { rm -f "$dest"; continue; }

        local min_size=$(identify -format '%[fx:min(w,h)]' "$dest" 2>/dev/null || echo "0")
        if [ "$min_size" -lt "${MIN_SIZE:-800}" ] 2>/dev/null; then
            rm -f "$dest"
            continue
        fi

        local title=$(echo "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('title','Unknown'))" 2>/dev/null)
        local artist=$(echo "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('artistDisplayName','') or 'Unknown Artist')" 2>/dev/null)
        local date=$(echo "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('objectDate','') or 'Date unknown')" 2>/dev/null)
        local medium=$(echo "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('medium',''))" 2>/dev/null)
        local dims=$(echo "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('dimensions',''))" 2>/dev/null)
        local credit=$(echo "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('creditLine',''))" 2>/dev/null)
        local url=$(echo "$data" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('objectURL',''))" 2>/dev/null)

        cat > "$META_DIR/${fname}.meta" <<METAEOF
title=${title}
artist=${artist}
date=${date}
style=${style}
medium=${medium}
dimensions=${dims}
credit=${credit}
url=${url}
METAEOF

        echo "$dest"
        return 0
    done
    return 1
}

log_to_db() {
    local img="$1"
    local fname=$(basename "$img")
    local meta="$META_DIR/${fname}.meta"
    [ -f "$meta" ] || return

    local met_id=$(echo "$fname" | sed 's/met-//;s/\.jpg//')
    local title=$(grep '^title=' "$meta" | cut -d= -f2-)
    local artist=$(grep '^artist=' "$meta" | cut -d= -f2-)
    local date=$(grep '^date=' "$meta" | cut -d= -f2-)
    local style=$(grep '^style=' "$meta" | cut -d= -f2-)
    local medium=$(grep '^medium=' "$meta" | cut -d= -f2-)
    local dims=$(grep '^dimensions=' "$meta" | cut -d= -f2-)
    local credit=$(grep '^credit=' "$meta" | cut -d= -f2-)
    local url=$(grep '^url=' "$meta" | cut -d= -f2-)

    sqlite3 "$DB_PATH" "INSERT INTO paintings (met_id, title, artist, date, style, medium, dimensions, credit, url)
        VALUES ('$(echo "$met_id" | sed "s/'/''/g")',
                '$(echo "$title" | sed "s/'/''/g")',
                '$(echo "$artist" | sed "s/'/''/g")',
                '$(echo "$date" | sed "s/'/''/g")',
                '$(echo "$style" | sed "s/'/''/g")',
                '$(echo "$medium" | sed "s/'/''/g")',
                '$(echo "$dims" | sed "s/'/''/g")',
                '$(echo "$credit" | sed "s/'/''/g")',
                '$(echo "$url" | sed "s/'/''/g")
        ');"
}

notify_and_rate() {
    local body=""
    local icon=""
    local met_ids=()

    for img in "$@"; do
        local fname=$(basename "$img")
        local meta="$META_DIR/${fname}.meta"
        [ -f "$meta" ] || continue

        local met_id=$(echo "$fname" | sed 's/met-//;s/\.jpg//')
        met_ids+=("$met_id")

        local title=$(grep '^title=' "$meta" | cut -d= -f2-)
        local artist=$(grep '^artist=' "$meta" | cut -d= -f2-)
        local date=$(grep '^date=' "$meta" | cut -d= -f2-)
        local style=$(grep '^style=' "$meta" | cut -d= -f2-)
        local medium=$(grep '^medium=' "$meta" | cut -d= -f2-)

        [ -n "$body" ] && body="${body}\n\n"
        body="${body}<span size='large'><b>${title}</b></span>\n<b>${artist}</b>\n${date} · ${style^}\n<i>${medium}</i>"
        [ -z "$icon" ] && icon="$img"
    done

    [ -z "$body" ] && return
    body="${body}\n<span size='small'>click to 👍</span>"

    action=$(send_notification " " "$body" "$icon" "like")

    if [ "$action" = "like" ]; then
        for mid in "${met_ids[@]}"; do
            "$SCRIPT_DIR/ecclesiastic-rate" "$mid" 1
        done
    fi
}

RESOLUTIONS=($(get_resolutions))
MONITORS=${#RESOLUTIONS[@]}
STYLE="${1:-${STYLES[$((RANDOM % ${#STYLES[@]}))]}}"

ORIGINALS=()
COMPOSED=()
prev=""
for ((i=0; i<MONITORS; i++)); do
    img=$(pick_from_pool "$STYLE" "$prev")
    if [ -z "$img" ]; then
        img=$(fetch_live "$STYLE")
    fi
    prev="$img"
    [ -z "$img" ] && continue
    ORIGINALS+=("$img")

    fname=$(basename "$img" .jpg)
    res="${RESOLUTIONS[$i]}"
    comp="$COMPOSE_DIR/${fname}-${res}.jpg"

    if [ ! -f "$comp" ]; then
        "$SCRIPT_DIR/ecclesiastic-compose" "$img" "$res" "$comp"
    fi
    [ -f "$comp" ] && COMPOSED+=("$comp") || COMPOSED+=("$img")
done

[ ${#COMPOSED[@]} -eq 0 ] && { send_notification "Ecclesiastic" "Failed to fetch painting" "" ""; exit 1; }

apply_pywal "${ORIGINALS[-1]}"
set_wallpaper "${COMPOSED[@]}"

for img in "${ORIGINALS[@]}"; do
    log_to_db "$img"
done

notify_and_rate "${ORIGINALS[@]}" &disown
